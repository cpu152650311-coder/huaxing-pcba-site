# HUAXING PCBA — Hostinger Apache .htaccess
# This site is a Next.js static export living in out/
# All requests are silently rewritten to out/ directory

Options -Indexes +MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On

# Prevent rewrite loops — only run on first pass
RewriteCond %{ENV:REDIRECT_STATUS} ^$

# If request already targets out/, let it through
RewriteCond %{REQUEST_URI} !^/out/

# Rewrite everything to out/ (Apache resolves index.html, .html extensions via MultiViews)
RewriteRule ^(.*)$ out/$1 [L]
</IfModule>

# ── Caching for static assets ──
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/png  "access plus 1 year"
ExpiresByType image/ico  "access plus 1 year"
ExpiresByType text/css   "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
</IfModule>
